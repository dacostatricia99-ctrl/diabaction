# Active la persistance PostgreSQL (false = repli sur les données de démo).
DB_ENABLED="false"

# Base de données PostgreSQL + PostGIS (cf. docker-compose.yml)
DATABASE_URL="postgresql://diabaction:diabaction@localhost:5432/diabaction?schema=public"

# Session (à générer : openssl rand -base64 32)
AUTH_SECRET="change-me"

# Notifications push Web (VAPID) — générer : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@diabaction.cg"
